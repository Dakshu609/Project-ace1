# ============================================
# DEPENDENCIES
# ============================================
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ============================================
# TESTING
# ============================================
/coverage
/test-results
/playwright-report
/playwright/.cache
/cypress/videos
/cypress/screenshots

# ============================================
# NEXT.JS BUILD OUTPUT
# ============================================
/.next/
/out/

# ============================================
# PRODUCTION BUILD
# ============================================
/build
/dist

# ============================================
# ENVIRONMENT VARIABLES (SECRETS)
# ============================================
# CRITICAL: Never commit these files — they contain secrets, API keys, tokens
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.staging
.env.staging.local
.env.production
.env.production.local

# Whitelist the template file (no secrets, safe to commit)
!.env.example

# ============================================
# DEVELOPMENT & DEBUG
# ============================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*

# ============================================
# OPERATING SYSTEM FILES
# ============================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.directory
.Trash-*

# ============================================
# IDE & EDITOR FILES
# ============================================
# VS Code (whitelist shared config)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# JetBrains (WebStorm, IntelliJ, GoLand)
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]
*.swp
*.swo
*.swn

# Sublime Text
*.sublime-workspace

# ============================================
# TYPESCRIPT
# ============================================
*.tsbuildinfo
next-env.d.ts

# ============================================
# DEPLOYMENT
# ============================================
.vercel
.netlify
.firebase

# ============================================
# CACHES, TEMPORARY FILES & LOCAL STATE
# ============================================
*.cache
.eslintcache
.stylelintcache
.turbo/

# ============================================
# LOGS
# ============================================
*.log

# ============================================
# DATABASE
# ============================================
# Local database files (do not commit development databases)
*.db
*.sqlite
*.sqlite3

# ============================================
# SUPABASE LOCAL DEVELOPMENT
# ============================================
supabase/.temp
.branches_*

# ============================================
# FILE UPLOADS & USER CONTENT
# ============================================
/public/uploads/
/uploads/
/storage/

# ============================================
# STRIPE CLI
# ============================================
.stripe/

# ============================================
# SECRETS & CERTIFICATES
# ============================================
*.pem
*.key
*.cert
*.p12
*.pfx

# ============================================
# BACKUP FILES
# ============================================
*.bak
*.backup

# ============================================
# TEMPORARY FILES
# ============================================
*.tmp
*.temp

# ============================================
# PACKAGE LOCK (ignore alien lock files, keep npm's)
# ============================================
yarn.lock
pnpm-lock.yaml
bun.lock
bun.lockb
# package-lock.json is intentionally committed
